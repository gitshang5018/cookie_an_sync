{
  "manifest_version": 3,
  "name": "Cookie Sync (Sender)",
  "version": "2.0.0",
  "description": "局域网 Cookie 同步工具 - 推送端",
"permissions": [
  "cookies",
  "storage",
  "alarms"
],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
