<Window x:Class="CookieSyncServer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CookieSyncServer"
        mc:Ignorable="d"
        Title="Cookie Sync Ultimate" Height="680" Width="440"
        Icon="icon.ico"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="48" 
                      ResizeBorderThickness="8" 
                      GlassFrameThickness="0" 
                      CornerRadius="18"/>
    </WindowChrome.WindowChrome>

    <Border CornerRadius="16" BorderThickness="1.5" Margin="8">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#4f46e5" Offset="0"/>
                <GradientStop Color="#3b82f6" Offset="0.5"/>
                <GradientStop Color="#10b981" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#020617" Offset="0.0"/>
                <GradientStop Color="#0f172a" Offset="0.4"/>
                <GradientStop Color="#1e1b4b" Offset="1.0"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" Direction="270" Opacity="0.7" ShadowDepth="0" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Ultra Modern Title Bar -->
            <Grid Grid.Row="0">
                <StackPanel Orientation="Horizontal" Margin="18,0">
                    <Image Source="icon.ico" Width="22" Height="22" Margin="0,0,12,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="COOKIE SYNC RELAY" Foreground="White" VerticalAlignment="Center" FontWeight="Bold" FontSize="13"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="" FontFamily="Segoe MDL2 Assets" Width="48" Height="48" Background="Transparent" Foreground="#94a3b8" BorderThickness="0" Click="Minimize_Click" FontSize="11">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#1e293b"/></Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="" FontFamily="Segoe MDL2 Assets" Width="48" Height="48" Background="Transparent" Foreground="#94a3b8" BorderThickness="0" Click="Close_Click" FontSize="11">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="0,16,0,0">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#ef4444"/><Setter Property="Foreground" Value="White"/></Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Glowing Status Dashboard -->
            <StackPanel Grid.Row="1" Margin="28,20,28,12">
                <Border CornerRadius="14" Padding="22" BorderThickness="1" BorderBrush="#1e293b">
                    <Border.Background>
                        <SolidColorBrush Color="#0f172a" Opacity="0.6"/>
                    </Border.Background>
                    <StackPanel>
                        <Grid>
                            <TextBlock x:Name="TxtPort" Text="等待启动服务..." Foreground="#818cf8" FontSize="22" FontWeight="ExtraBold"/>
                            <Ellipse Width="10" Height="10" Fill="#10b981" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Ellipse.Effect><BlurEffect Radius="8"/></Ellipse.Effect>
                            </Ellipse>
                        </Grid>
                        
                        <Border Height="1" Background="#1e293b" Margin="0,18"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel>
                                <TextBlock Text="活跃站点" Foreground="#64748b" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                                <TextBlock x:Name="TxtDomain" Text="无" Foreground="White" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            
                            <Border Grid.Column="1" Width="1" Background="#1e293b" Margin="20,5"/>
                            
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="同步节点" Foreground="#64748b" FontSize="10" FontWeight="Bold" Margin="0,0,0,6" HorizontalAlignment="Right"/>
                                <TextBlock x:Name="TxtTime" Text="---" Foreground="White" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Glass Interaction Panel -->
            <Grid Grid.Row="2" Margin="28,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <Border Background="#020617" CornerRadius="10" BorderThickness="1" BorderBrush="#334155" Height="42">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="4" Background="#6366f1" CornerRadius="4,0,0,4"/>
                            <TextBlock Text="PORT" Foreground="#475569" FontWeight="Black" FontSize="9" VerticalAlignment="Center" Margin="14,0,10,0"/>
                            <TextBox x:Name="InputPort" Text="3000" Width="60" VerticalAlignment="Center" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="15" FontWeight="Bold" CaretBrush="White"/>
                        </StackPanel>
                    </Border>
                    <CheckBox x:Name="ChkAutoStart" Content="开机自动启动" Foreground="#94a3b8" FontSize="11" Margin="4,8,0,0" Click="AutoStart_Click" Cursor="Hand"/>
                </StackPanel>

                <Button x:Name="BtnToggle" Grid.Row="0" Grid.Column="1" Content="启动中转服务" Click="ToggleServer_Click" Width="140" Height="42" Foreground="White" BorderThickness="0" FontWeight="Bold" FontSize="13">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#6366f1"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#4f46e5"/></Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Cyber Log Console -->
            <Grid Grid.Row="3" Margin="28,12,28,28">
                <Border Background="#000000" Opacity="0.8" CornerRadius="12" BorderThickness="1" BorderBrush="#1e293b" Padding="12">
                    <ListBox x:Name="LogList" Background="Transparent" Foreground="#10b981" BorderThickness="0" FontFamily="Consolas" FontSize="11" ScrollViewer.VerticalScrollBarVisibility="Hidden">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0,3"/>
                                <Setter Property="Focusable" Value="False"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border BorderThickness="0,0,0,1" BorderBrush="#0f172a" Padding="2">
                                                <ContentPresenter />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
